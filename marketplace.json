        "target": "accounts.json"
      }
    },
    {
      "id": "cloudflare-email-setup",
      "name": "cloudflare-email-setup",
      "displayName": "Cloudflare 免费邮箱转发",
      "description": "自动化配置 Cloudflare Email Routing，零成本拥有自定义域名邮箱，支持多开储备和隐私保护",
      "version": "1.0.0",
      "path": "./cloudflare-email-setup",
      "entry": "skill.md",
      "commands": [
        "/cf-email setup",
        "/cf-email add",
        "/cf-email list",
        "/cf-email status",
        "/cf-email test",
        "/cf-email remove"
      ],
      "category": "privacy",
      "tags": ["email", "cloudflare", "privacy", "domain", "forwarding"],
      "requirements": {
        "python": "3.8+",
        "packages": ["dnspython"]
      }
    }
  ],
  "installation": {
    "script": "./install.sh",
    "manual": [
      "cp -r free-token ~/.openclaw/workspace/agents/xueer/skills/",
      "cp -r cloudflare-email-setup ~/.openclaw/workspace/agents/xueer/skills/",
      "pip3 install requests dnspython"
    ]
